    "decisions": {
      "state_management": {
        "package": "provider",
        "version": "^6.0.5",
        "pattern": "ChangeNotifier + Consumer",
        "justification": "Existing app already uses Provider (ChangeNotifier pattern). PRD has 2 screens, no real-time features, no complex shared state. Keeping existing BudgetModel as ChangeNotifier preserves data layer per PRD constraint."
      },
      "navigation": {
        "package": "go_router",
        "version": "^14.2.0",
        "pattern": "simple named routes",
        "justification": "Only 2 screens, no deep links, no complex auth flow. go_router provides clean navigation with minimal overhead."
      },
      "local_storage": {
        "package": "shared_preferences",
        "version": "^2.2.2",
        "justification": "PRD data.storage == 'local', offline_support == true, data is simple structured list of transactions. Existing app already uses SharedPreferences. No complex queries needed."
      },
      "api_client": {
        "package": "none",
        "version": null,
        "justification": "PRD data.backend_required == false. No external API calls needed."
      },
      "auth": {
        "package": null,
        "token_storage": null,
        "justification": "PRD auth.required == false. No authentication needed."
      },
      "di": {
        "package": "provider",
        "justification": "Provider IS the DI system. ChangeNotifierProvider provides BudgetModel. No additional DI package needed."
      },
      "config": {
        "packages": []
      },
      "observability": {
        "packages": [],
        "justification": "size_hint == 'small'. No remote error tracking needed."
      }
    },
