  "idea": {
    "raw_input": "Update the budget screen: make it functional \u2014 users can edit budgets, delete budgets, set different saving goals. Make budget cards compact/smaller. Display real data from BudgetModel instead of mock numbers.",
    "clarifications": []
  },
  "prd": {
    "version": "1.0",
    "drafted_at": "2026-05-24T05:51:40.587042+00:00",
    "approved": true,
    "approved_at": "2026-05-24T05:51:40.587042+00:00",
    "overview": {
      "problem": "The Budgets & Goals screen shows static/hardcoded budget categories with no way to edit or delete them, only one hardcoded savings goal, and budget cards are too large.",
      "solution": "Add edit and delete functionality for budget categories, support multiple configurable savings goals, and make budget cards compact.",
      "target_user": "Fortuna budget app users who want to customize their budget categories and savings goals.",
      "success_metric": "Users can edit budget category names/limits, delete categories, add/remove saving goals, and budget cards display in a compact layout."
    },
    "screens": [
      {
        "id": "SCR-001",
        "name": "BudgetsGoalsScreen",
        "purpose": "Display, edit, and delete budget categories and savings goals with compact card layout.",
        "primary_actions": [
          "Edit budget category",
          "Delete budget category",
          "Add new budget",
          "Edit savings goals",
          "Delete savings goal"
        ],
        "navigation_to": []
      },
      {
        "id": "SCR-002",
        "name": "EditBudgetDialog",
        "purpose": "Dialog popup to edit a budget category name and spending limit.",
        "primary_actions": [
          "Save edits",
          "Cancel"
        ],
        "navigation_to": []
      },
      {
        "id": "SCR-003",
        "name": "SavingsGoalDialog",
        "purpose": "Dialog popup to add/edit a savings goal name, target amount, and current amount.",
        "primary_actions": [
          "Save goal",
          "Cancel"
        ],
        "navigation_to": []
      }
    ],
    "features": [
      {
        "id": "FEA-001",
        "name": "Edit budget category",
        "priority": "must_have",
        "description": "User can tap edit on any budget category card to modify its name and spending limit via a dialog.",
        "screens_involved": [
          "SCR-001",
          "SCR-002"
        ],
        "acceptance_criteria": [
          "Given a budget category card, when user taps edit icon, then a dialog appears with pre-filled name and limit fields.",
          "Given the edit dialog is open, when user changes values and taps Save, then the category updates in real-time on the budget screen.",
          "Given the edit dialog is open, when user taps Cancel or dismisses, then no changes are saved."
        ]
      },
      {
        "id": "FEA-002",
        "name": "Delete budget category",
        "priority": "must_have",
        "description": "User can delete a budget category. Default categories cannot be deleted.",
        "screens_involved": [
          "SCR-001"
        ],
        "acceptance_criteria": [
          "Given a custom budget category card, when user taps delete, then a confirmation dialog appears.",
          "Given the confirmation dialog is shown, when user confirms, then the category is removed from the list.",
          "Given a default budget category card, when user views options, then delete is not available."
        ]
      },
      {
        "id": "FEA-003",
        "name": "Add new budget category",
        "priority": "must_have",
        "description": "User can add a new custom budget category with a name and spending limit.",
        "screens_involved": [
          "SCR-001",
          "SCR-002"
        ],
        "acceptance_criteria": [
          "Given the budget screen, when user taps 'New Budget', then a dialog opens to enter category name and limit.",
          "Given the add dialog, when user enters valid data and saves, then the new category appears in the list.",
          "Given the add dialog, when user enters a duplicate name, then an error is shown."
        ]
      },
      {
        "id": "FEA-004",
        "name": "Multiple savings goals",
        "priority": "must_have",
        "description": "Users can set multiple savings goals instead of a single hardcoded one. Each goal has a name and target amount.",
        "screens_involved": [
          "SCR-001",
          "SCR-003"
        ],
        "acceptance_criteria": [
          "Given the budget screen, the savings goals section shows all saved goals.",
          "Given the savings goals section, when user taps add, then a dialog opens to enter goal name and target.",
          "Given a savings goal card, when user taps delete, then it is removed after confirmation.",
          "Given zero savings goals, an empty prompt is shown encouraging the user to add one."
        ]
      },
      {
        "id": "FEA-005",
        "name": "Compact budget cards",
        "priority": "must_have",
        "description": "Budget category cards are redesigned to be smaller and more compact.",
        "screens_involved": [
          "SCR-001"
        ],
        "acceptance_criteria": [
          "Given the budget screen, when viewed on mobile, then at least 2 category cards are visible without scrolling.",
          "Given a compact budget card, when viewed, then it shows category name, spent/limit, progress bar, and edit/delete actions.",
          "Given a compact budget card, the padding and spacing is reduced."
        ]
      }
    ],
