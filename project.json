    "overview": {
      "problem": "Users need a dedicated screen to view budget categories, track spending progress, and monitor savings goals.",
      "solution": "A Budgets & Goals screen with hero section, summary stats, active categories grid with color-coded progress indicators, and active savings goal card.",
      "target_user": "Fortuna budget app users.",
      "success_metric": "Users can view all active budget categories with spending progress, total monthly limit, and active savings goals."
    },
    "screens": [
      {
        "id": "SCR-001",
        "name": "BudgetsGoalsScreen",
        "purpose": "Display all active budget categories with spending progress, total monthly limit, and active savings goals.",
        "primary_actions": [
          "View budget categories",
          "View total monthly limit",
          "View active goals",
          "Tap New Budget button"
        ],
        "navigation_to": []
      }
    ],
    "features": [
      {
        "id": "FEA-001",
        "name": "Budget Categories Grid",
        "priority": "must_have",
        "description": "Display active budget category cards with progress bars and status indicators.",
        "screens_involved": [
          "SCR-001"
        ],
        "acceptance_criteria": [
          "Category cards show spent/limit, progress bar, status indicators for healthy/warning/critical."
        ]
      },
      {
        "id": "FEA-002",
        "name": "Total Monthly Limit Summary Card",
        "priority": "must_have",
        "description": "Summary card with total limit, spent, percentage, remaining.",
        "screens_involved": [
          "SCR-001"
        ],
        "acceptance_criteria": [
          "Displays total limit, spent, percentage, remaining with progress bar."
        ]
      },
      {
        "id": "FEA-003",
        "name": "Active Goal Card",
        "priority": "must_have",
        "description": "Card showing active savings goal with progress.",
        "screens_involved": [
          "SCR-001"
        ],
        "acceptance_criteria": [
          "Displays goal name, target, current, percentage, icon."
        ]
      },
      {
        "id": "FEA-004",
        "name": "Hero Section",
        "priority": "must_have",
        "description": "Hero with title, subtitle, New Budget button.",
        "screens_involved": [
          "SCR-001"
        ],
        "acceptance_criteria": [
          "Displays title, subtitle, button."
        ]
      },
      {
        "id": "FEA-005",
        "name": "Bottom Nav Integration",
        "priority": "must_have",
        "description": "Wire to Budgets tab in bottom nav.",
        "screens_involved": [
          "SCR-001"
        ],
        "acceptance_criteria": [
          "Budgets tab shows screen with active styling."
        ]
      }
    ],
