  "meta": {
    "project_id": "budget-app-screen-update",
    "project_name": "Fortuna Budget App",
    "size_hint": "small",
    "current_phase": "BUILD",
    "created_at": "2026-05-24T05:49:40.542078+00:00",
    "updated_at": "2026-05-24T08:20:00.000000+00:00"
  },
  "idea": {
    "raw_input": "Update the budget screen: make it functional \u2014 users can edit budgets, delete budgets, set different saving goals. Make budget cards compact/smaller. Display real data from BudgetModel instead of mock numbers.",
    "clarifications": []
  },
  "prd": {
    "version": "1.1",
    "drafted_at": "2026-05-24T08:00:00.000000+00:00",
    "approved": true,
    "approved_at": "2026-05-24T08:00:00.000000+00:00",
    "overview": {
      "problem": "When adding a new budget category on the Budgets screen, users can type any arbitrary name. This means budgets can be created for categories that don't exist as expense categories in settings, leading to mismatched data.",
      "solution": "Replace the free-text name input in the Add Budget dialog with a dropdown selector that only shows existing expense categories (from CategorySettingsModel) that don't already have a budget.",
      "target_user": "Fortuna budget app users who set budgets for their expense categories.",
      "success_metric": "Users can only select from real expense categories when creating a budget. No arbitrary or income categories are available."
    },
    "screens": [
      {
        "id": "SCR-001",
        "name": "BudgetsGoalsScreen",
        "purpose": "Display budget categories. 'New Budget' button opens dialog with expense category dropdown.",
        "primary_actions": [
          "Add budget for existing expense category"
        ],
        "navigation_to": []
      },
      {
        "id": "SCR-002",
        "name": "EditBudgetDialog",
        "purpose": "Dialog to create a budget for an existing expense category with a spending limit.",
        "primary_actions": [
          "Select expense category",
          "Set limit",
          "Save"
        ],
        "navigation_to": []
      }
    ],
    "features": [
      {
        "id": "FEA-001",
        "name": "Restrict budget categories to existing expense categories",
        "priority": "must_have",
        "description": "When adding a new budget, users must select from existing expense categories defined in CategorySettingsModel. Income categories are excluded. Already-budgeted categories are excluded.",
        "screens_involved": [
          "SCR-001",
          "SCR-002"
        ],
        "acceptance_criteria": [
          "Given the Add Budget dialog, when opened, then only existing expense categories without budgets are shown in the dropdown.",
          "Given all expense categories already have budgets, when user opens Add Budget, then the dropdown is empty and a message is shown.",
          "Given the Add Budget dialog, when user selects a category and sets a limit and saves, then a new budget category is created.",
          "Income categories (Salary, Business, etc.) are never shown in the Add Budget dropdown."
        ]
      }
    ],
    "auth": {
      "required": false,
      "methods": [],
      "guest_mode": false
    },
    "data": {
      "storage": "local",
      "backend_required": false,
      "backend_notes": "Category list comes from CategorySettingsModel (SharedPreferences). Budget categories stored in BudgetGoalsModel."
    },
    "integrations": [],
